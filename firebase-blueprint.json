{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to user's profile picture" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A generated SaaS project configuration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this project" },
        "name": { "type": "string" },
        "config": { "type": "object", "description": "The full JSON configuration of the project" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "config"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Private user profile data"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User-generated SaaS projects"
    }
  }
}
